PORT=8787
HOST=127.0.0.1
DATA_DIR=./data
PUBLIC_DIR=./public
SESSION_TTL_DAYS=7
MAX_JSON_BYTES=5242880
MAX_ASSET_BYTES=5242880
CORS_ORIGIN=*
STORAGE_PREFIX=thesis-editor-v1

# Vercel Marketplace 连接 Upstash 后会自动注入，无需提交真实密钥：
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Upstash 控制台使用的变量名也受支持：
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
